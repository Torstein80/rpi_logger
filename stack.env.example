APP_HOST=0.0.0.0
APP_PORT=8080
DEFAULT_POLL_SECONDS=10
DEFAULT_INTERVAL_SECONDS=10
DEFAULT_TIMEZONE_OFFSET=+02:00
DB_PATH=/data/logger.db
EXPORT_DIR=/data/exports
W1_BASE_PATH=/sys/bus/w1/devices
SENSOR_LABELS=28-xxxxxxxxxxxx:Probe A,28-yyyyyyyyyyyy:Probe B
HTTPS_CERTFILE=/certs/cert.pem
HTTPS_KEYFILE=/certs/key.pem

NETWORK_MANAGER_ENABLED=true
NETWORK_AP_INTERFACE=wlan0
NETWORK_AP_CONNECTION_NAME=haga-fallback-ap
NETWORK_WIRED_INTERFACE=eth0
NETWORK_WIRED_CONNECTION_NAME=haga-eth0
