# Fallback / rescue Wi-Fi access point
AP_SSID=hagasolutions-rpi-logger
AP_PASSWORD=ChangeMe1234
AP_INTERFACE=wlan0
AP_ADDRESS_CIDR=10.77.0.1/24

# Wired network profile for eth0
# MODE can be: auto or manual
WIRED_MODE=auto
WIRED_CONNECTION_NAME=haga-eth0
WIRED_INTERFACE=eth0
WIRED_IP_CIDR=10.87.0.5/24
WIRED_GATEWAY=
WIRED_DNS=

# Hostname advertised over mDNS/Bonjour
PI_HOSTNAME=hagasolutions-rpi-logger
